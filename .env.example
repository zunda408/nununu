# Threads AI Agent System – Required Environment Variables
# Copy this file to .env and fill in the values.

# ---------------------------------------------------------------------
# Anthropic Claude API
# ---------------------------------------------------------------------
# API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use (default: claude-3-5-haiku-20241022)
CLAUDE_MODEL=claude-3-5-haiku-20241022

# ---------------------------------------------------------------------
# Threads / Meta API
# ---------------------------------------------------------------------
# Long-lived access token obtained via Meta for Developers
# https://developers.facebook.com/docs/threads/get-started
THREADS_ACCESS_TOKEN=your_threads_access_token_here

# Threads user ID (numeric string, e.g. "1234567890")
THREADS_USER_ID=your_threads_user_id_here

# ---------------------------------------------------------------------
# Pipeline Defaults (optional)
# ---------------------------------------------------------------------
# Default content niche (e.g. "テクノロジー", "ライフスタイル")
DEFAULT_NICHE=

# Number of topics to research and post per pipeline run (default: 3)
DEFAULT_TOPICS_COUNT=3
